# === 编排层 LLM（Claude）：记忆抽取 / 问答 / 周报 / 任务拆解，Slice 1 起需要 ===
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# 本地 JSONL 调用日志；配置每日预算时，会按同一天日志累计估算成本，超额前阻断调用；图片 OCR 启用后也走这条日志/预算边界。
HOMEAGENT_LLM_LOG_PATH=./.homeagent-llm.jsonl
HOMEAGENT_LLM_DAILY_BUDGET_USD=
# 为避免硬编码会过期的模型价格，预算单价需显式填写（美元 / 百万 token）。
HOMEAGENT_LLM_INPUT_USD_PER_MILLION_TOKENS=
HOMEAGENT_LLM_OUTPUT_USD_PER_MILLION_TOKENS=
HOMEAGENT_LLM_MAX_OUTPUT_TOKENS=1024

# === gbrain embedding provider（务实型隐私：可用云端，选其一填 key）===
OPENAI_API_KEY=
# VOYAGE_API_KEY=
# ZEROENTROPY_API_KEY=

# === gbrain ===
HOMEAGENT_CONNECTOR=cli          # cli | feishu
GBRAIN_BIN=gbrain
# gbrain init 后的 default source 通常是 federated 且没有 local_path。
# 若要让 runDreamCycle 自动注册/同步本地 markdown source，建议把 GBRAIN_SOURCE 改成非 default（如 homebrain）并填写 GBRAIN_SOURCE_PATH。
GBRAIN_SOURCE=default
GBRAIN_SOURCE_PATH=
HOMEBRAIN_DIR=./.brain          # 作为 GBRAIN_HOME；gbrain 会写 ./.brain/.gbrain/（已 gitignore）
HOMEAGENT_DB_PATH=./.homeagent.sqlite

# === 任务派发 scheduler（Slice 5）===
# 配置后会把当天待派发任务发到该 channel；CLI connector 默认 channel 是 cli。
HOMEAGENT_TASK_CHANNEL_ID=
HOMEAGENT_TASK_DISPATCH_INTERVAL_MS=86400000
HOMEAGENT_TASK_DISPATCH_ON_START=0

# === 主动播报 scheduler（Slice 4）===
# 配置后会让 homebrain 生成家庭早报/周报/那年今日并发送到对应 channel。
HOMEAGENT_BRIEFING_CHANNEL_ID=
HOMEAGENT_BRIEFING_INTERVAL_MS=86400000
HOMEAGENT_BRIEFING_ON_START=0
HOMEAGENT_WEEKLY_CHANNEL_ID=
HOMEAGENT_WEEKLY_INTERVAL_MS=604800000
HOMEAGENT_WEEKLY_ON_START=0
HOMEAGENT_ON_THIS_DAY_CHANNEL_ID=
HOMEAGENT_ON_THIS_DAY_INTERVAL_MS=86400000
HOMEAGENT_ON_THIS_DAY_ON_START=0

# === 成员画像周期性归纳（Slice 3/4）===
# 启用后会定期按成员向 homebrain.ask 提炼长期画像事实，再写入 partners/<slug>/USER.md。
HOMEAGENT_PROFILE_REFRESH_ENABLED=0
HOMEAGENT_PROFILE_REFRESH_INTERVAL_MS=86400000
HOMEAGENT_PROFILE_REFRESH_ON_START=0

# === 飞书 bot（Slice 2 才需要）===
LARK_BIN=lark-cli
FEISHU_EVENT_KEY=im.message.receive_v1
# bot 的 open_id，用于识别并剥掉 @bot 标签；Feishu connector 启动时会校验。
FEISHU_BOT_OPEN_ID=
# 可选：配置后会用 lark-cli im +messages-resources-download 下载图片/文件到本地相对路径，并把 localPath 写入附件元数据。
FEISHU_ATTACHMENT_DOWNLOAD_DIR=.homeagent/attachments
# 可选：本地文本附件（txt/md/csv/json/log）最多读取多少字节写入附件内容。
HOMEAGENT_ATTACHMENT_TEXT_MAX_BYTES=16384
# 可选：显式开启后，图片附件会发送给 Claude Vision 做文字提取；默认关闭，调用会复用 LLM JSONL 日志/预算。
HOMEAGENT_IMAGE_OCR_ENABLED=0
# 可选：单张图片 OCR 最多读取多少字节。Claude API 直接 base64 图片上限是 10MB，这里默认更保守。
HOMEAGENT_IMAGE_OCR_MAX_BYTES=5242880
